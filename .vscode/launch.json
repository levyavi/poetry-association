{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Python: Run poem_assoc web app",
      "type": "debugpy",
      "request": "launch",
      "module": "poem_assoc",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": true,
      "envFile": "${workspaceFolder}/.env",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/src"
      }
    },
    {
      "name": "Python: Import sample CSV",
      "type": "debugpy",
      "request": "launch",
      "module": "poem_assoc",
      "args": [
        "import-csv",
        "${workspaceFolder}/sample_data/sample_poems.csv"
      ],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": true,
      "envFile": "${workspaceFolder}/.env",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/src"
      }
    },
    {
      "name": "Python: pytest",
      "type": "debugpy",
      "request": "launch",
      "module": "pytest",
      "args": [
        "-q"
      ],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": true,
      "envFile": "${workspaceFolder}/.env",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/src"
      }
    },
    {
      "name": "PowerShell: Run task automation",
      "type": "PowerShell",
      "request": "launch",
      "script": "${workspaceFolder}/scripts/run_tasks.ps1",
      "cwd": "${workspaceFolder}",
      "args": [
        "-StartTask",
        "001"
      ]
    }
  ]
}
