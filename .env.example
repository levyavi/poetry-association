# Path to the SQLite database file.
# Default: ./poem_assoc.db (relative to working directory)
POEM_DB_PATH=./poem_assoc.db

# Flask secret key used for session signing.
# Default: a random value generated per-process (not suitable for production).
POEM_SECRET_KEY=change-me-to-a-long-random-string

# Admin password for the /admin area.
# Required starting Task 005. Leave empty for tasks 001-004.
POEM_ADMIN_PASSWORD=

# Name of the sentence-transformers model to load.
# Default: all-MiniLM-L6-v2
POEM_MODEL_NAME=all-MiniLM-L6-v2

# Optional local filesystem path to the model directory.
# If set, the model is loaded from this path instead of the default cache.
# POEM_MODEL_PATH=
